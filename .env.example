# =============================================================================
# Intrynsic Community Engagement Agent — credentials
# -----------------------------------------------------------------------------
# Copy this file to ".env" (no extension) and fill in the real values.
# NEVER commit .env to git or paste it into a chat. Keep it local.
# =============================================================================

# --- Reddit account (the single account that handles all subreddits) ---------
REDDIT_USERNAME=
REDDIT_PASSWORD=

# --- Reddit API app (official OAuth API — works through your VPN) -------------
# Create a "script" app at https://www.reddit.com/prefs/apps
# NOTE: the prefs/apps PAGE is blocked on your work network and on datacenter
# VPN IPs. Create the app ONCE from home wifi or a personal phone hotspot; the
# resulting strings then work from this machine via the API.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# --- Quora login (used by Playwright for the first login; cookies are saved) --
QUORA_EMAIL=
QUORA_PASSWORD=

# --- Twitter / X (browser automation; log in once via: python twitter_login.py) --
# Username is only used to build the "view your profile" link in the email (optional).
TWITTER_USERNAME=

# --- Gmail for sending the digest + confirmation emails -----------------------
# Use a Gmail App Password (NOT your normal password):
#   https://myaccount.google.com/apppasswords  (requires 2-Step Verification)
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=
# Where digests/confirmations are sent (defaults to GMAIL_ADDRESS if left blank)
DIGEST_RECIPIENT=

# --- Drafting model API key --------------------------------------------------
# Default provider is Groq (free, high daily limit). Get a FREE key at
# https://console.groq.com/keys
GROQ_API_KEY=
# Optional fallback provider — Gemini (free tier is only ~20 drafts/day).
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
